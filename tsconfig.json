{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "types": ["node"],
    "noEmit": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["engine/**/*.ts"]
}
