{
  "name": "blind-four",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "tsx --test engine/*.test.ts server/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sanity": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "server:dev": "tsx watch server/index.ts",
    "web:dev": "npm --prefix web run dev",
    "dev": "trap 'kill 0' SIGINT EXIT; npm run server:dev & npm run web:dev"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "socket.io": "^4.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0",
    "jiti": "^2.7.0",
    "prettier": "3.8.3",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
